APP_NAME="PullLog E2E"
APP_ENV=e2e
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:3030
APP_FRONTEND_URL=https://127.0.0.1:4173

APP_LOCALE=ja
APP_FALLBACK_LOCALE=ja
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=pulllog_e2e
# Fallback when the local role cannot CREATE DATABASE:
# DB_DATABASE=pulllog
# DB_SCHEMA=e2e,public
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=array
CACHE_KEY_VERSION=e2e-v1

MAIL_MAILER=array
MAIL_FROM_ADDRESS="noreply@pulllog.test"
MAIL_FROM_NAME="${APP_NAME}"

DEMO_EMAIL=demo@pulllog.net
DEMO_USER_IDS=2

CORS_ALLOWED_ORIGINS=https://127.0.0.1:4173,https://localhost:4173
CORS_ALLOWED_METHODS=POST,GET,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Origin,X-Requested-With,Content-Type,Accept,x-api-key,x-csrf-token

API_BASE_URI=/api/v1
API_KEY=e2e-local-key
SANCTUM_STATEFUL_DOMAINS=127.0.0.1:4173,localhost:4173

GOOGLE_CLIENT_ID=dummy-e2e-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=dummy-e2e-client-secret
GOOGLE_REDIRECT_URI=https://127.0.0.1:4173/auth/callback

GALLERY_DISK=public
GALLERY_BASE_DIR=gallery-e2e
GALLERY_SIGNED_URL_TTL=120
GALLERY_UPLOAD_TICKET_TTL=60
GALLERY_PUBLIC_HOST=https://127.0.0.1:4173
